# OpenClaw (required)
TELEGRAM_BOT_TOKEN=
OPENAI_API_KEY=

# Optional: extra gateway control UI CORS origins (comma-separated). Merged into allowedOrigins on each container start.
OPENCLAW_ALLOWED_ORIGIN=

# Optional: pass through if the gateway uses token auth (otherwise leave empty for local pairing)
OPENCLAW_GATEWAY_TOKEN=

# Dashboard pairing auto-approve (PM2 app openclaw-auto-approve; polls until one pending request exists, then approves and exits)
OPENCLAW_AUTO_APPROVE_INTERVAL=10
OPENCLAW_HEALTH_URL=http://127.0.0.1:18789/healthz

# c9sdk file manager (supervisor / pm2)
C9SDK_PASSWORD=changeme
