# OpenClaw (required)
TELEGRAM_BOT_TOKEN=
OPENAI_API_KEY=

# Optional: extra gateway control UI CORS origins (comma-separated). Merged into allowedOrigins on each container start.
OPENCLAW_ALLOWED_ORIGIN=

# Optional: initial OpenClaw npm version to install on first boot of a fresh /root/.openclaw volume.
# Examples: latest, 0.4.7
INITIAL_OPENCLAW_VERSION=latest

# Optional: add one OpenAI-compatible custom model provider on each container start.
# When set, this provider becomes agents.defaults.model.primary.
# Leave OPENAI_API_KEY blank to remove the default OpenAI provider config.
# Required together: CUSTOM_PROVIDER_NAME, CUSTOM_PROVIDER_API_KEY, CUSTOM_PROVIDER_BASE_URL, CUSTOM_PROVIDER_MODEL_ID
CUSTOM_PROVIDER_NAME=
CUSTOM_PROVIDER_API_KEY=
CUSTOM_PROVIDER_BASE_URL=
CUSTOM_PROVIDER_MODEL_ID=
# Optional defaults: api-key, openai-completions, CUSTOM_PROVIDER_MODEL_ID, CUSTOM_PROVIDER_API
CUSTOM_PROVIDER_AUTH=
CUSTOM_PROVIDER_API=
CUSTOM_PROVIDER_MODEL_NAME=
CUSTOM_PROVIDER_MODEL_API=

# Optional: pass through if the gateway uses token auth (otherwise leave empty for local pairing)
OPENCLAW_GATEWAY_TOKEN=

# Dashboard pairing auto-approve (PM2 app openclaw-auto-approve; polls until one pending request exists, then approves and exits)
OPENCLAW_AUTO_APPROVE_INTERVAL=10
OPENCLAW_HEALTH_URL=http://127.0.0.1:18789/healthz

# c9sdk file manager (supervisor / pm2)
C9SDK_PASSWORD=changeme
